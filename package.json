{
  "name": "monday-countries-front",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run stop && concurrently \"npm run dev:app\" \"npm run expose\"",
    "dev:app": "vite",
    "build": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "expose": "node ./scripts/tunnel.mjs",
    "stop": "node ./scripts/stop.mjs"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bootstrap": "^5.3.3",
    "monday-sdk-js": "^0.5.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-bootstrap": "^2.10.2",
    "sass": "^1.77.5"
  },
  "overrides": {
    "nth-check": "2.0.1",
    "postcss": "8.4.31",
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    },
    "minimatch@5.1.9": {
      "brace-expansion": "2.0.3"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "2.0.3"
    }
  },
  "devDependencies": {
    "@mondaycom/apps-cli": "^4.10.5",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "cross-port-killer": "^1.2.1",
    "typescript": "^5.8.3",
    "vite": "^6.4.1"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ]
}
